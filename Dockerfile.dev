# Dockerfile для dev-режима — бэкенд с hot-reload.
# Исходники монтируются volume'ом в /app/backend; editable-установка
# указывает на этот же путь, поэтому правки кода подхватываются --reload.
FROM python:3.12-slim

WORKDIR /app/backend

# Копируем бэкенд (app/ нужен setuptools для editable-сборки)
COPY backend/ ./

# Editable-установка пакета с dev-зависимостями
RUN pip install --no-cache-dir -e ".[dev]"

ENV DB_PATH=/app/data/protocol.db
ENV DEBUG=true
ENV PYTHONUNBUFFERED=1

EXPOSE 8000

# Сервер с автоперезагрузкой. Миграции применяются в lifespan приложения.
CMD ["sh", "-c", "uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload"]
