# Пример переменных окружения для продакшн-деплоя.
# Скопируйте в .env и задайте свои значения: cp .env.example .env
# Файл .env в git не попадает (см. .gitignore).

# Пароль PostgreSQL. Используется сервисом postgres и строкой DATABASE_URL.
POSTGRES_PASSWORD=change-me-strong-password

# URL подключения к БД (asyncpg). В docker-compose задаётся автоматически через POSTGRES_PASSWORD.
# Явно задайте здесь только если используете внешний PostgreSQL.
# DATABASE_URL=postgresql+asyncpg://protocol:пароль@postgres:5432/protocol

# Секретный ключ для подписи JWT. Сгенерировать: openssl rand -hex 32
# ВНИМАНИЕ: смена ключа разлогинит всех пользователей.
# Обязателен в проде (DEBUG=False): с дефолтным значением приложение не стартует.
SECRET_KEY=change-me-use-openssl-rand-hex-32

# Первый администратор — создаётся ТОЛЬКО при первом запуске (пустая таблица users).
# После старта смените пароль в UI; правка этих переменных потом ни на что не влияет.
FIRST_ADMIN_USERNAME=admin
FIRST_ADMIN_PASSWORD=change-me

# Необязательное: время жизни токенов и CORS (по умолчанию заданы в config.py).
# ACCESS_TOKEN_EXPIRE_MINUTES=30
# REFRESH_TOKEN_EXPIRE_DAYS=7
# ALLOWED_ORIGINS=https://protocol.example.com

# Запускать миграции Alembic при старте приложения (по умолчанию True).
# Поставьте False, если применяете миграции отдельным шагом (entrypoint/job/CI).
# RUN_MIGRATIONS_ON_STARTUP=True
